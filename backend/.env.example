# --- Database (Neon PostgreSQL) ---
DB_HOST=your-neon-host.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASSWORD=your_db_password
DB_NAME=neondb
DB_SSLMODE=require

# --- Django ---
DJANGO_SECRET_KEY=generate_with_get_random_secret_key
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Kakao OAuth ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- Naver OAuth ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
