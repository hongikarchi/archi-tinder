# --- Database (Neon PostgreSQL) ---
DB_HOST=your-neon-host.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASSWORD=your_db_password
DB_NAME=neondb
DB_SSLMODE=require

# --- Django ---
DJANGO_SECRET_KEY=generate_with_get_random_secret_key
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Images (Cloudflare R2) ---
IMAGE_BASE_URL=https://pub-5d2133d166fc4b65ad05295df352519f.r2.dev

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key

# --- HuggingFace (Stage 2 embedding API per IMP-6) ---
HF_TOKEN=your_huggingface_api_token

# --- Feature flags ---
# IMP-6: parse_query 2-stage decouple. Set 'true' to enable async stage 2 path.
STAGE_DECOUPLE_ENABLED=false

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Kakao OAuth ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- Naver OAuth ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- Dev Login (automated testing only — set a long random string) ---
DEV_LOGIN_SECRET=
