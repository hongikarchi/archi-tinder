VITE_API_BASE_URL=http://localhost:8001/api/v1

# Social login client IDs (public — safe to expose in frontend)
VITE_GOOGLE_CLIENT_ID=
VITE_KAKAO_JS_KEY=
VITE_NAVER_CLIENT_ID=
VITE_NAVER_CALLBACK_URL=http://localhost:5174/auth/naver/callback

# Dev-only: bypass OAuth in local development (must match backend DEV_LOGIN_SECRET)
# Leave empty in production. The Dev Login button only renders when import.meta.env.DEV is true.
VITE_DEV_LOGIN_SECRET=
